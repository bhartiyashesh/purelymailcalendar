# SMTP / IMAP / ManageSieve servers (Purelymail defaults - legacy CLI only)
SMTP_HOST=smtp.purelymail.com
SMTP_PORT=465
IMAP_HOST=imap.purelymail.com
IMAP_PORT=993
SIEVE_HOST=mailserver.purelymail.com
SIEVE_PORT=4190

# Magic-link transactional email
# Preferred path: Resend.
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=calinvite

# Fallback path: SMTP. Used if RESEND_API_KEY is unset.
# MAGIC_LINK_SMTP_HOST=smtp.purelymail.com
# MAGIC_LINK_SMTP_PORT=465
# MAGIC_LINK_SMTP_USER=you@yourdomain.com
# MAGIC_LINK_SMTP_PASS=replace
# MAGIC_LINK_FROM_EMAIL=you@yourdomain.com
# MAGIC_LINK_FROM_NAME=calinvite

# Base URL used to build the magic-link href. In dev this is your Vite host.
BASE_URL=http://127.0.0.1:5173

# Session secret + encryption key (set in prod; auto-generated locally).
# FERNET_KEY=
# COOKIE_SECURE=true
